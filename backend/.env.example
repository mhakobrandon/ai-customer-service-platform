# Database Configuration
# Option 1: PostgreSQL (Recommended for production)
# DATABASE_URL=postgresql://serviceuser:your_secure_password@localhost:5432/ai_customer_service

# Option 2: SQLite (Quick start - no installation required)
DATABASE_URL=sqlite+aiosqlite:///./ai_customer_service.db

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (Optional - for caching)
# If you don't have Redis, the app will work without it
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
APP_NAME=AI-Powered Customer Service Platform
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# NLP Model Configuration
NLP_MODEL_NAME=xlm-roberta-base
NLP_MODEL_PATH=./models
NLP_CONFIDENCE_THRESHOLD=0.85
SUPPORTED_LANGUAGES=en,sn,nd

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@customerservice.com

# Twilio / WhatsApp Integration (Optional - required for live WhatsApp chatbot)
# Use Twilio sandbox or approved WhatsApp sender in production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=500

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Performance
MAX_UPLOAD_SIZE=10485760
RATE_LIMIT_PER_MINUTE=60
